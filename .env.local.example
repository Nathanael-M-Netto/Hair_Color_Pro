# ============================================================
# Hair Color Pro v2 — variáveis de ambiente
# ============================================================
# Copiar para `.env.local` e preencher. NÃO commitar `.env.local`.

# ─── Firebase Auth + Firestore ──────────────────────────────
# Projeto: arte-de-colorir-cabelos (mesmo do app Flutter)
# Como obter: Firebase Console → Project Settings → Your apps → Web App → Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=arte-de-colorir-cabelos.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=arte-de-colorir-cabelos
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=arte-de-colorir-cabelos.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=205375342353
NEXT_PUBLIC_FIREBASE_APP_ID=1:205375342353:web:b07166e0699c88dc1d2eb0
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK (SERVER ONLY — não prefixar com NEXT_PUBLIC_)
# Como obter: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Baixar o JSON e copiar os três campos abaixo (private_key precisa de aspas + \n literal).
FIREBASE_PROJECT_ID=arte-de-colorir-cabelos
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Google Gemini (relatório textual da análise) ───────────
# Como obter: https://aistudio.google.com/apikey (grátis, free tier ~1500 req/dia)
# Modelo recomendado: gemini-2.5-flash-lite (rápido, gratuito).
# Outras opções: gemini-2.5-flash, gemini-3.1-flash-lite-preview
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ─── Telemetria (opcional) ──────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ─── Feature flags ──────────────────────────────────────────
# Liga/desliga efeitos visuais pesados em dispositivos low-end.
NEXT_PUBLIC_ENABLE_BITS=true

# ─── Build mode ─────────────────────────────────────────────
# 'export' para Capacitor (Bloco H, mobile nativo), vazio para Next normal (Vercel).
NEXT_OUTPUT_MODE=
